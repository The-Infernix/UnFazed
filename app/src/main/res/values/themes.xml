<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Unfazed" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Color palette -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_very_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/warning_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/accent_purple</item>
        <item name="colorError">@color/error</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Typography - Using system fonts -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.Unfazed.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Unfazed.Headline2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Unfazed.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Unfazed.Body2</item>

        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Unfazed.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Unfazed.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Unfazed.Large</item>
    </style>

    <!-- Typography Styles - Using system fonts -->
    <style name="TextAppearance.Unfazed.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Unfazed.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Unfazed.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.Unfazed.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Shape Styles -->
    <style name="ShapeAppearance.Unfazed.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Unfazed.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Unfazed.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>