<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp">

    <!-- Timeline Line -->
    <View
        android:id="@+id/timelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp" />

    <!-- Status Dot -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/circle_active"
        app:layout_constraintTop_toTopOf="@id/taskCard"
        app:layout_constraintBottom_toBottomOf="@id/taskCard"
        app:layout_constraintStart_toStartOf="@id/timelineLine"
        app:layout_constraintEnd_toEndOf="@id/timelineLine" />

    <!-- Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/taskCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/timelineLine"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSemesterTag"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Semester 3"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:textStyle="bold"
                    android:textAllCaps="true"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="80dp"
                    android:layout_height="4dp"
                    android:progressTint="@color/success"
                    android:progress="50"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Master Data Structures"
                android:textSize="18sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Focus on Arrays, Linked Lists, and Trees."
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Expanded Content (Visible for ACTIVE/COMPLETED) -->
            <LinearLayout
                android:id="@+id/layoutExpanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp">

                <!-- Timeline & Hours -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvTimeline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⏰ Month 1-3"
                        android:textSize="12sp"
                        android:textColor="#757575"/>

                    <TextView
                        android:id="@+id/tvEstimatedHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 120 hours"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <!-- Resources Chips -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupResources"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

            </LinearLayout>

            <!-- Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTaskAction"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Learning"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                android:textColor="@color/primary"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>