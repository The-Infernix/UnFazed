<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/timelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp" />

    <View
        android:id="@+id/statusDot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/circle_active"
        app:layout_constraintTop_toTopOf="@id/taskCard"
        app:layout_constraintBottom_toBottomOf="@id/taskCard"
        app:layout_constraintStart_toStartOf="@id/timelineLine"
        app:layout_constraintEnd_toEndOf="@id/timelineLine" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/taskCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/timelineLine"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSemesterTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semester 3"
                android:textSize="12sp"
                android:textColor="#757575"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Master Data Structures"
                android:textSize="18sp"
                android:textColor="#212121"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Focus on Arrays, Linked Lists, and Trees."
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTaskAction"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open DigiFac Labs"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:icon="@android:drawable/ic_menu_directions" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>